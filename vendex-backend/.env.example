# ============================================================================
# Vendex backend config — copy to .env and fill in real values.
# The real .env is gitignored. NEVER commit real keys.
# ============================================================================

# --- REQUIRED ---------------------------------------------------------------
# Postgres (Neon). Use a separate Neon project from the Supplier Tracker's DB.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Google Gemini (AI Studio). New keys look like: AQ.Ab8...  (or older AIza...)
GEMINI_API_KEY=

# --- LIKELY NEEDED (Alibaba data API via RapidAPI) --------------------------
RAPIDAPI_KEY=

# --- OPTIONAL (sensible fallbacks exist if omitted) -------------------------
SERP_API_KEY=
IMGBB_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=reelsource

# --- AUTH (backend admin/view passwords) ------------------------------------
ADMIN_PASSWORD=change-me
VIEW_PASSWORD=change-me

# --- WEBHOOK (frontend notified when a job finishes) ------------------------
NEXTJS_WEBHOOK_URL=http://localhost:3001/api/webhooks/job-update
NEXTJS_WEBHOOK_SECRET=change-me

# --- PIPELINE / RUNTIME -----------------------------------------------------
DOWNLOAD_DIR=./downloads
FRAME_OUTPUT_DIR=./frames
MAX_CONCURRENT_JOBS=2
RATE_LIMIT_ALIBABA_PER_MIN=25
RATE_LIMIT_SERPAPI_PER_MIN=5
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
ENVIRONMENT=development

# --- WINDOWS PATHS (this machine) -------------------------------------------
FFMPEG_LOCATION=C:\path\to\ffmpeg

# --- Daily production/ETA reminder trigger (calls the Supplier Tracking app) -
REMINDER_APP_URL=http://localhost:3000
REMINDER_CRON_SECRET=change-me

# --- TELEGRAM SUPPLIER BOT --------------------------------------------------
# When set, the backend long-polls Telegram: send the bot a PRODUCT PHOTO and
# it replies with the best supplier (price + product link) plus other suppliers.
TELEGRAM_BOT_TOKEN=
