# PostgreSQL connection (Neon). Copy this file to .env and fill in real values.
# Neon → your project → Connection Details.
#   DATABASE_URL: the POOLED connection string (host contains "-pooler").
#   DIRECT_URL:   the DIRECT connection string (host WITHOUT "-pooler").
# Keep the ?sslmode=require suffix on both.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth — run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="generate-a-random-32-byte-base64-string"
NEXTAUTH_URL="http://localhost:3000"

# Vendex scraper bridge (optional — only if using Sourcing Model auto-fill)
VENDEX_API_URL="http://127.0.0.1:8001"
VENDEX_API_TOKEN=""

# Telegram bot (reminders + the supplier-finder bot share ONE bot token).
# Create a bot via @BotFather, paste its token here. TELEGRAM_CHAT_ID is the
# group/chat reminders are pushed to (discover it via /api/reminders/chat-id).
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
REMINDER_CRON_SECRET="generate-a-random-secret"

# Supplier-finder bot: secret that authenticates Telegram's webhook calls to
# /api/telegram/webhook (any long random string — Telegram echoes it back in a
# header so we can verify the request really came from Telegram).
TELEGRAM_WEBHOOK_SECRET="generate-a-random-secret"
# Re-ranking blend when a #tag is used: image weight (0–1). Default 0.6 (60%
# image + 40% price/top/review). Leave unset to use the default.
RANK_IMAGE_WEIGHT="0.6"
# Set to 1 to force mock supplier data (test the bot without a real search backend).
BOT_MOCK_SUPPLIERS="0"
# Supplier search sources (priority: TMAPI wholesale → SerpAPI retail → mock).
# TMAPI (tmapi.top) — 1688/Alibaba image search returning WHOLESALE / FOB prices.
# This is the preferred source for sourcing. Get an apiToken from the TMAPI console.
TMAPI_TOKEN=""
TMAPI_BASE_URL="https://api.tmapi.top"
# SerpAPI (serpapi.com) — Google Lens reverse-image search (RETAIL prices). Used
# as a fallback when TMAPI has no match. Set BOT_MOCK_SUPPLIERS=0 to use real data.
SERPAPI_KEY=""
# ImgBB (api.imgbb.com) — reliable image host. The bot uploads the user's photo
# here to get a public URL for the image search. Free key. Strongly recommended:
# the free no-auth hosts (catbox/tmpfiles) throttle and fail under load.
IMGBB_KEY=""

# Anthropic API key — powers the bot's database Q&A. When set, addressing the bot
# with a question (e.g. "@bot how many products are in post-order?") makes Claude
# answer using READ-ONLY database tools. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=""
