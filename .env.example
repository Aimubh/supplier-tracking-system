# PostgreSQL connection (Neon). Copy this file to .env and fill in real values.
# Neon → your project → Connection Details.
#   DATABASE_URL: the POOLED connection string (host contains "-pooler").
#   DIRECT_URL:   the DIRECT connection string (host WITHOUT "-pooler").
# Keep the ?sslmode=require suffix on both.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth — run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="generate-a-random-32-byte-base64-string"
NEXTAUTH_URL="http://localhost:3000"

# Vendex scraper bridge (optional — only if using Sourcing Model auto-fill)
VENDEX_API_URL="http://127.0.0.1:8001"
VENDEX_API_TOKEN=""
