{
  "name": "supplier-tracking-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "node --env-file=.env prisma/seed.mjs",
    "db:seed:example": "node --env-file=.env prisma/seed-example.mjs",
    "db:backup": "node --env-file=.env prisma/backup.mjs",
    "db:restore": "node --env-file=.env prisma/restore.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.408.0",
    "motion": "^12.40.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  }
}
